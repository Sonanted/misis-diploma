# Auth
JWT_SECRET=            # any long random string
JWT_EXPIRES_IN_MS=86400000  # token lifetime in ms (86400000 = 24h)
SALT_ROUNDS=10         # bcrypt rounds (10 is a safe default)

# Bank
TOPUP_PASSWORD=        # password required to top up accounts via API

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=           # your postgres password
DB_NAME=diploma-db

# Frontend
FRONTEND_URL=http://localhost:3000  # used for CORS origin
